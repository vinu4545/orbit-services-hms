{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "env": {
    "NITRO_PRESET": "node-server"
  },
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}

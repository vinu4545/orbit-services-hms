{
  "buildCommand": "npm run build",
  "env": {
    "VERCEL": "true"
  },
  "functions": {
    "dist/server/server.mjs": {
      "runtime": "nodejs20.x",
      "includeFiles": "dist/**/*"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/assets/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/server/server.mjs"
    }
  ]
}
